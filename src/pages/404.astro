---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../config";
import Header from "../components/Header.astro";

const lang = "en";
const t = (await import(`../i18n/${lang}.json`)).default;
---

<Layout lang={lang}>
  <Header lang={lang} />
  <main class="flex min-h-screen items-center justify-center px-6">
    <div class="text-center">
      <h1 class="text-8xl font-extrabold tracking-tight text-ink-faint">404</h1>
      <p class="mt-4 text-xl text-ink-muted">{t["404"].description}</p>
      <a
        href="/"
        class="mt-8 inline-flex h-11 items-center gap-2 rounded-xl bg-accent px-6 text-sm font-semibold text-white shadow-lg shadow-accent/25 transition-all duration-300 hover:bg-accent-light active:scale-[0.98]"
      >
        {t["404"].go_home}
      </a>
    </div>
  </main>
</Layout>
