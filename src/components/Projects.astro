---
import SectionTitle from "./SectionTitle.astro";
import ScrollReveal from "./ScrollReveal.astro";
import ProjectCard from "./ProjectCard.astro";
import { PROJECTS } from "../config";

export interface Props {
  lang: "en" | "es";
}

const { lang } = Astro.props;
const t = (await import(`../i18n/${lang}.json`)).default;
const isEn = lang === "en";
---

<section id="projects" class="relative py-14 md:py-20">
  <div class="section-container">
    <ScrollReveal>
      <SectionTitle title={t.projects.title} />
    </ScrollReveal>

    <div class="grid gap-4 md:grid-cols-2">
      {PROJECTS.map((project, i) => (
        <ScrollReveal delay={i * 80}>
          {project.url ? (
            <a
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class="glass-card group relative flex h-full flex-col overflow-hidden p-5 transition-all duration-300 hover:-translate-y-0.5 hover:border-accent/20 sm:p-6"
            >
              <ProjectCard project={project} isEn={isEn} viewLabel={t.projects.view_project} />
            </a>
          ) : (
            <div class="glass-card group relative flex h-full flex-col overflow-hidden p-5 sm:p-6">
              <ProjectCard project={project} isEn={isEn} viewLabel={t.projects.view_project} />
            </div>
          )}
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
