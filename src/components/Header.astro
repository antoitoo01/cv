---
import LanguageToggle from "./LanguageToggle.astro";
import ThemeToggle from "./ThemeToggle.astro";

export interface Props {
  lang: "en" | "es";
}

const { lang } = Astro.props;
const t = (await import(`../i18n/${lang}.json`)).default;

const navLinks = [
  { href: "#about", label: t.nav.about },
  { href: "#skills", label: t.nav.skills },
  { href: "#projects", label: t.nav.projects },
  { href: "#experience", label: t.nav.experience },
  { href: "#education", label: t.nav.education },
  { href: "#contact", label: t.nav.contact },
];
---

<header class="fixed left-0 right-0 top-0 z-50 border-b border-border-subtle bg-surface/80 backdrop-blur-xl">
  <nav
    class="section-container flex h-14 items-center justify-between"
    aria-label="Main navigation"
  >
    <a
      href={lang === "en" ? "/cv/" : "/cv/es"}
      class="group flex h-8 w-8 items-center justify-center rounded-xl bg-gradient-to-br from-accent/20 to-accent/5 text-sm font-bold tracking-tight text-accent-light ring-1 ring-accent/20 transition-all duration-300 hover:from-accent/30 hover:to-accent/10 hover:ring-accent/40 hover:shadow-lg hover:shadow-accent/10"
      aria-label="Home"
    >
      AT
    </a>

    <div class="flex items-center gap-3">
      <ul class="hidden items-center gap-5 md:flex">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class="link-underline text-xs font-medium text-ink-muted transition-colors hover:text-ink"
            >
              {label}
            </a>
          </li>
        ))}
      </ul>

      <ThemeToggle />
      <LanguageToggle lang={lang} />

      <button
        class="flex h-8 w-8 items-center justify-center rounded-lg border border-border-subtle text-ink-muted transition-all hover:border-accent/30 hover:bg-accent/10 hover:text-accent-light md:hidden"
        aria-label="Toggle menu"
        id="menu-toggle"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="hidden border-t border-border-subtle bg-surface/95 backdrop-blur-xl"
  >
    <ul class="section-container flex flex-col gap-1 py-3">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="block rounded-lg px-4 py-2.5 text-sm font-medium text-ink-muted transition-colors hover:bg-surface-50 hover:text-ink"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const isHidden = menu.classList.contains("hidden");
      menu.classList.toggle("hidden");
      toggle.setAttribute("aria-expanded", String(!isHidden));
    });

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        menu.classList.add("hidden");
        toggle?.setAttribute("aria-expanded", "false");
      });
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        menu.classList.add("hidden");
        toggle?.setAttribute("aria-expanded", "false");
      }
    });
  }
</script>
