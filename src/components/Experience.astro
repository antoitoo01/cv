---
import SectionTitle from "./SectionTitle.astro";
import ScrollReveal from "./ScrollReveal.astro";
import { EXPERIENCE } from "../config";

export interface Props {
  lang: "en" | "es";
}

const { lang } = Astro.props;
const t = (await import(`../i18n/${lang}.json`)).default;
const isEn = lang === "en";

const typeLabels: Record<string, { en: string; es: string }> = {
  freelance: { en: "Freelance", es: "Freelance" },
  fulltime: { en: "Full-Time", es: "Jornada Completa" },
  internship: { en: "Internship", es: "Prácticas" },
  training: { en: "Training", es: "Formación" },
};
---

<section id="experience" class="relative py-14 md:py-20">
  <div class="section-container">
    <ScrollReveal>
      <SectionTitle title={t.experience.title} />
    </ScrollReveal>

    <div class="relative pl-6">
      <div class="timeline-line" aria-hidden="true" />

      <div class="space-y-5">
        {EXPERIENCE.map((exp, i) => {
          const typeInfo = exp.type ? typeLabels[exp.type] : null;
          return (
          <ScrollReveal delay={i * 80}>
            <div class="group relative">
              <div class="timeline-dot transition-all duration-300 group-hover:scale-150 group-hover:bg-accent" />

              <div class={`glass-card p-4 transition-all duration-300 hover:border-accent/20 sm:p-5 ${exp.type === "freelance" ? "border-accent/10" : ""}`}>
                <div class="flex flex-wrap items-start justify-between gap-1.5">
                  <div>
                    <div class="flex items-center gap-1.5">
                      <h3 class="text-sm font-bold text-ink">
                        {isEn ? exp.role.en : exp.role.es}
                      </h3>
                      {typeInfo && (
                        <span class="rounded bg-accent/10 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-accent-light">
                          {isEn ? typeInfo.en : typeInfo.es}
                        </span>
                      )}
                    </div>
                    <p class="mt-0.5 text-xs font-medium text-accent-light">
                      {exp.company}
                    </p>
                  </div>
                  <div class="text-right">
                    <p class="text-xs font-medium text-ink-dim">
                      {isEn ? exp.period.en : exp.period.es}
                    </p>
                    <p class="text-[11px] text-ink-faint">{exp.location}</p>
                  </div>
                </div>
                <p class="mt-2 text-xs leading-relaxed text-ink-muted">
                  {isEn ? exp.description.en : exp.description.es}
                </p>
                {exp.url && (
                  <a
                    href={exp.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-2 inline-flex items-center gap-1 text-[11px] font-medium text-accent-light transition-colors hover:text-accent"
                  >
                    {exp.url.replace(/^https?:\/\//, "")}
                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </a>
                )}
              </div>
            </div>
          </ScrollReveal>
          );
        })}
      </div>
    </div>


  </div>
</section>
