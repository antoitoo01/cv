---
import SectionTitle from "./SectionTitle.astro";
import ScrollReveal from "./ScrollReveal.astro";
import { SKILLS, TECHNOLOGY_ICONS } from "../config";

export interface Props {
  lang: "en" | "es";
}

const { lang } = Astro.props;
const t = (await import(`../i18n/${lang}.json`)).default;

const skillCategories: {
  label: string;
  icon: string;
  skills: readonly string[];
}[] = [
  { label: "Backend", icon: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4", skills: SKILLS.backend },
  { label: "Frontend", icon: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z", skills: SKILLS.frontend },
  { label: "Mobile", icon: "M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z", skills: SKILLS.mobile },
  { label: "DevOps & Tools", icon: "M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z", skills: SKILLS.devops },
  { label: "Databases", icon: "M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4", skills: SKILLS.databases },
  { label: "Testing", icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z", skills: SKILLS.testing },
  { label: "Data & Analytics", icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z", skills: SKILLS.data },
];
---

<section id="skills" class="relative py-14 md:py-20">
  <div class="section-container">
    <ScrollReveal>
      <SectionTitle title={t.skills.title} />
    </ScrollReveal>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {skillCategories.map(({ label, icon, skills }, catIndex) => (
        <ScrollReveal delay={catIndex * 80}>
          <div class="glass-card group relative overflow-hidden p-4 transition-all duration-300 hover:border-accent/20 sm:p-5">
            <div class="flex items-center gap-2.5">
              <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-accent/10">
                <svg class="h-3.5 w-3.5 text-accent-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
                </svg>
              </div>
              <h3 class="text-xs font-semibold tracking-wider uppercase text-ink-muted">
                {label}
              </h3>
            </div>

            <div class="mt-3 flex flex-wrap gap-1.5">
              {skills.map((skill) => (
                <span
                  key={skill}
                  class="inline-flex items-center gap-1.5 rounded-md bg-surface-50 px-2 py-1 text-xs font-medium text-ink-muted transition-colors hover:bg-accent/10 hover:text-accent-light"
                >
                  {TECHNOLOGY_ICONS[skill] && (
                    <img
                      src={TECHNOLOGY_ICONS[skill]}
                      alt=""
                      class="h-3.5 w-3.5 opacity-60 grayscale transition-all duration-300 group-hover:opacity-100 group-hover:grayscale-0"
                      loading="lazy"
                    />
                  )}
                  {skill}
                </span>
              ))}
            </div>
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
