---
import { SITE } from "../config";
import ScrollReveal from "./ScrollReveal.astro";
import TechIllustration from "./TechIllustration.astro";

export interface Props {
  lang: "en" | "es";
}

const { lang } = Astro.props;
const t = (await import(`../i18n/${lang}.json`)).default;
---

<section class="relative flex min-h-[80vh] items-center overflow-hidden pt-14">
  <div
    class="pointer-events-none absolute -top-40 right-0 h-[500px] w-[500px] opacity-15"
    aria-hidden="true"
  >
    <div class="h-full w-full rounded-full bg-gradient-radial from-accent/30 via-accent/10 to-transparent blur-3xl" />
  </div>

  <div class="section-container w-full py-12">
    <div class="grid items-center gap-8 lg:grid-cols-2 lg:gap-16">
      <div class="max-w-3xl">
        <ScrollReveal>
          <p class="mb-3 text-xs font-semibold tracking-widest uppercase text-accent-light">
            {t.hero.greeting}
          </p>
        </ScrollReveal>

        <ScrollReveal delay={100}>
          <h1 class="text-3xl font-extrabold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl">
            <span class="gradient-text">{SITE.name}</span>
          </h1>
        </ScrollReveal>

        <ScrollReveal delay={200}>
          <p class="mt-3 max-w-2xl text-base font-medium text-ink-secondary sm:text-lg md:text-xl">
            {t.hero.tagline}
          </p>
        </ScrollReveal>

        <ScrollReveal delay={300}>
          <p class="mt-4 max-w-2xl text-sm leading-relaxed text-ink-muted sm:text-base">
            {t.hero.description}
          </p>
        </ScrollReveal>

        <ScrollReveal delay={400}>
          <div class="mt-8 flex flex-wrap items-center gap-3">
            <a
              href="#projects"
              class="inline-flex h-10 items-center gap-1.5 rounded-xl bg-accent px-5 text-sm font-semibold text-white shadow-lg shadow-accent/25 transition-all duration-300 hover:bg-accent-light hover:shadow-accent/40 active:scale-[0.98]"
            >
              {t.hero.cta_projects}
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </a>

            <a
              href={SITE.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-10 items-center gap-1.5 rounded-xl border border-border-default px-5 text-sm font-medium text-ink-muted transition-all duration-300 hover:border-accent/30 hover:bg-accent/10 hover:text-accent-light"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              GitHub
            </a>

            <a
              href="#contact"
              class="inline-flex h-10 items-center gap-1.5 rounded-xl border border-border-default px-5 text-sm font-medium text-ink-muted transition-all duration-300 hover:border-accent/30 hover:bg-accent/10 hover:text-accent-light"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {t.hero.cta_contact}
            </a>
          </div>
        </ScrollReveal>
      </div>

      <ScrollReveal delay={250} class="hidden justify-self-center lg:flex">
        <TechIllustration />
      </ScrollReveal>
    </div>
  </div>
</section>
