---
import SectionTitle from "./SectionTitle.astro";
import ScrollReveal from "./ScrollReveal.astro";
import { EDUCATION } from "../config";

export interface Props {
  lang: "en" | "es";
}

const { lang } = Astro.props;
const t = (await import(`../i18n/${lang}.json`)).default;
const isEn = lang === "en";
---

<section id="education" class="relative py-14 md:py-20">
  <div class="section-container">
    <ScrollReveal>
      <SectionTitle title={t.education.title} />
    </ScrollReveal>

    <div class="relative pl-6">
      <div class="timeline-line" aria-hidden="true" />

      <div class="space-y-5">
        {EDUCATION.map((edu, i) => {
          const eduTypeInfo = edu.type === "degree"
            ? { en: "Degree", es: "Titulación" }
            : { en: "Course", es: "Curso" };
          return (
          <ScrollReveal delay={i * 80}>
            <div class="group relative">
              <div class="timeline-dot transition-all duration-300 group-hover:scale-150 group-hover:bg-accent" />

              <div class={`glass-card p-4 transition-all duration-300 hover:border-accent/20 sm:p-5 ${edu.type === "degree" ? "border-accent/10" : ""}`}>
                <div class="flex flex-wrap items-start justify-between gap-1.5">
                  <div>
                    <div class="flex items-center gap-1.5">
                      <span class="rounded bg-accent/10 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-accent-light">
                        {isEn ? eduTypeInfo.en : eduTypeInfo.es}
                      </span>
                      <h3 class="text-sm font-bold text-ink">
                        {isEn ? edu.degree.en : edu.degree.es}
                      </h3>
                    </div>
                    <p class="mt-0.5 text-xs font-medium text-accent-light">
                      {edu.school}
                    </p>
                  </div>
                  <div class="text-right shrink-0">
                    <p class="text-xs font-medium text-ink-dim">
                      {isEn ? edu.period.en : edu.period.es}
                    </p>
                  </div>
                </div>
                <p class="mt-2 text-xs leading-relaxed text-ink-muted">
                  {isEn ? edu.description.en : edu.description.es}
                </p>
              </div>
            </div>
          </ScrollReveal>
          );
        })}
      </div>
    </div>
  </div>
</section>
