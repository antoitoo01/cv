---
import SectionTitle from "./SectionTitle.astro";
import ScrollReveal from "./ScrollReveal.astro";

export interface Props {
  lang: "en" | "es";
}

const { lang } = Astro.props;
const t = (await import(`../i18n/${lang}.json`)).default;
---

<section id="about" class="relative py-14 md:py-20">
  <div class="section-container">
    <ScrollReveal>
      <SectionTitle title={t.about.title} />
    </ScrollReveal>

    <div class="grid gap-8 lg:grid-cols-5">
      <div class="lg:col-span-3">
        <ScrollReveal delay={100}>
          <p class="prose-custom text-sm sm:text-base">
            {t.about.bio_1}
          </p>
        </ScrollReveal>

        <ScrollReveal delay={200}>
          <p class="prose-custom mt-4 text-sm sm:text-base">
            {t.about.bio_2}
          </p>
        </ScrollReveal>
      </div>

      <div class="lg:col-span-2">
        <ScrollReveal delay={300}>
          <div class="glass-card p-5 sm:p-6">
            <h3 class="mb-4 text-xs font-semibold tracking-widest uppercase text-ink-muted">
              {t.about.focus_title}
            </h3>
            <ul class="space-y-3">
              {[
                { label: t.about.focus_1, icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" },
                { label: t.about.focus_2, icon: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" },
                { label: t.about.focus_3, icon: "M13 10V3L4 14h7v7l9-11h-7z" },
                { label: t.about.focus_4, icon: "M13 10V3L4 14h7v7l9-11h-7z" },
              ].map(({ label, icon }) => (
                <li class="flex items-start gap-2.5">
                  <svg
                    class="mt-0.5 h-4 w-4 shrink-0 text-accent"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.5"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
                  </svg>
                  <span class="text-sm font-medium text-ink-secondary">{label}</span>
                </li>
              ))}
            </ul>
          </div>
        </ScrollReveal>
      </div>
    </div>
  </div>
</section>
